# Looka environment variables.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# OpenAI API key — used by the juan, suvi, and joe agent wrappers (cheap model).
OPENAI_API_KEY=

# OpenAI model (optional) — defaults to gpt-5.4-mini when unset.
OPENAI_MODEL=gpt-5.4-mini

# OpenAI Realtime model for Frank's voice orb (optional). Defaults to gpt-realtime-2.
OPENAI_REALTIME_MODEL=gpt-realtime-2

# OpenClaw token — used by frank's OpenClaw agent wrapper.
OPENCLAW_TOKEN=

# OpenClaw gateway URL — frank's wrapper needs BOTH the token and this URL set
# to reach a real gateway; otherwise it returns a clear placeholder.
OPENCLAW_GATEWAY_URL=

# Port the backend API listens on. Vite proxies /api here in dev;
# in prod the backend serves the built frontend on this same port.
PORT=8787
